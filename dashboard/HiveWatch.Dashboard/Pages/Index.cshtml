@page
@model IndexModel
@{
    ViewData["Title"] = "HiveWatch Dashboard";
}

<section class="mb-4">
    <h1 class="display-5">HiveWatch Cloud Edition IoT</h1>
    <p class="lead">
        Dashboard-facing monitoring view using the hosted GetRecentTelemetry retrieval path.
    </p>
    <p class="text-muted small mb-0">
        Automatic dashboard refresh is enabled every 5 minutes 30 seconds.
    </p>
</section>

@if (Model.HasError)
{
    <div class="alert alert-warning" role="alert">
        <strong>Status:</strong> @Model.StatusMessage
    </div>
}
else
{
    <div class="alert alert-success" role="alert">
        <strong>Status:</strong> @Model.StatusMessage
    </div>
}

@if (Model.LatestReading is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 card-title">Latest temperature</h2>
                    <p class="display-6 mb-0">
                        @Model.LatestReading.Value.ToString("0.00") &deg;@Model.LatestReading.Unit
                    </p>
                    <p class="text-muted mb-0">
                        Sensor type: @Model.LatestReading.Type
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 card-title">Device</h2>
                    <p class="mb-1"><strong>Device ID:</strong> @Model.LatestReading.DeviceId</p>
                    <p class="mb-0"><strong>Sensor ID:</strong> @Model.LatestReading.SensorId</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 card-title">Received</h2>
                    <p class="mb-1">
                        @Model.LatestReading.ReceivedAtUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
                    </p>
                    <p class="text-muted mb-0">
                        Source: Azure Table Storage via GetRecentTelemetry
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5 card-title">Freshness</h2>
                    <div class="alert @Model.FreshnessAlertClass py-2 mb-2" role="alert">
                        <strong>@Model.FreshnessStatus</strong>
                    </div>
                    <p class="text-muted mb-0">
                        @Model.FreshnessMessage
                    </p>
                </div>
            </div>
        </div>
    </div>

    <section class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h2 class="h4 mb-1">Baseline analytics</h2>
                    <p class="text-muted mb-0">
                        Simple summary statistics calculated from the latest retrieved temperature readings.
                        These support monitoring and inspection prioritisation, not biological diagnosis.
                    </p>
                </div>
                <span class="badge bg-secondary text-white">
                    @Model.AnalyticsSummary.ReadingCount reading(s)
                </span>
            </div>

            @if (Model.AnalyticsSummary.HasReadings)
            {
                <div class="row g-3 mb-3">
                    <div class="col-6 col-md-2">
                        <div class="border rounded p-3 h-100">
                            <h3 class="h6 text-muted">Latest</h3>
                            <p class="h4 mb-0">
                                @((Model.AnalyticsSummary.LatestValue ?? 0).ToString("0.00")) &deg;@Model.AnalyticsSummary.Unit
                            </p>
                        </div>
                    </div>

                    <div class="col-6 col-md-2">
                        <div class="border rounded p-3 h-100">
                            <h3 class="h6 text-muted">Minimum</h3>
                            <p class="h4 mb-0">
                                @((Model.AnalyticsSummary.MinimumValue ?? 0).ToString("0.00")) &deg;@Model.AnalyticsSummary.Unit
                            </p>
                        </div>
                    </div>

                    <div class="col-6 col-md-2">
                        <div class="border rounded p-3 h-100">
                            <h3 class="h6 text-muted">Maximum</h3>
                            <p class="h4 mb-0">
                                @((Model.AnalyticsSummary.MaximumValue ?? 0).ToString("0.00")) &deg;@Model.AnalyticsSummary.Unit
                            </p>
                        </div>
                    </div>

                    <div class="col-6 col-md-2">
                        <div class="border rounded p-3 h-100">
                            <h3 class="h6 text-muted">Average</h3>
                            <p class="h4 mb-0">
                                @((Model.AnalyticsSummary.AverageValue ?? 0).ToString("0.00")) &deg;@Model.AnalyticsSummary.Unit
                            </p>
                        </div>
                    </div>

                    <div class="col-6 col-md-2">
                        <div class="border rounded p-3 h-100">
                            <h3 class="h6 text-muted">Median</h3>
                            <p class="h4 mb-0">
                                @((Model.AnalyticsSummary.MedianValue ?? 0).ToString("0.00")) &deg;@Model.AnalyticsSummary.Unit
                            </p>
                            <p class="small text-muted mb-0">Mid-point value</p>
                        </div>
                    </div>

                    <div class="col-6 col-md-2">
                        <div class="border rounded p-3 h-100">
                            <h3 class="h6 text-muted">Trend</h3>
                            <div class="fs-4 fw-bold rounded px-3 py-2 text-center @Model.AnalyticsSummary.TrendBadgeClass">@Model.AnalyticsSummary.TrendStatus</div>
                        </div>
                    </div>
                </div>

                <p class="small text-muted mb-0">
                    @Model.AnalyticsSummary.TrendMessage
                </p>
            }
            else
            {
                <div class="alert alert-secondary mb-0" role="alert">
                    No temperature readings are available for analytics.
                </div>
            }
        </div>
    </section>

    <section class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h2 class="h4 mb-1">Brood-area alert status</h2>
                    <p class="text-muted mb-0">
                        Applies evidence-informed brood-area thresholds to the latest persisted temperature reading.
                        This is a monitoring risk signal, not a diagnosis of brood damage.
                    </p>
                </div>
                <span class="badge @Model.TemperatureAlert.BootstrapBadgeClass">
                    @Model.TemperatureAlert.AlertTrafficLight
                </span>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <h3 class="h6">Current temperature band</h3>
                    <div class="alert @Model.TemperatureAlert.BootstrapAlertClass mb-2" role="alert">
                        <strong>@Model.TemperatureAlert.AlertCategoryDescription</strong>
                        <div>@Model.TemperatureAlert.BroodAreaTemperatureBand</div>
                    </div>
                    <p class="small text-muted mb-0">
                        Evidence confidence: @Model.TemperatureAlert.EvidenceConfidence
                    </p>
                </div>

                <div class="col-md-4">
                    <h3 class="h6">Sustained alert check</h3>
                    <div class="alert @Model.TemperatureAlert.SustainedAlertClass mb-2" role="alert">
                        <strong>@Model.TemperatureAlert.SustainedStatus</strong>
                    </div>
                    <p class="small text-muted mb-1">
                        @Model.TemperatureAlert.SustainedMessage
                    </p>
                    <p class="small text-muted mb-0">
                        Readings evaluated: @Model.TemperatureAlert.ReadingsEvaluated
                    </p>
                </div>

                <div class="col-md-4">
                    <h3 class="h6">Meaning</h3>
                    <p class="mb-2">
                        @Model.TemperatureAlert.Meaning
                    </p>
                    <p class="small text-muted mb-0">
                        Sustained definition: @Model.TemperatureAlert.SustainedDefinition
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h2 class="h4 mb-1">Recent readings</h2>
                    <p class="text-muted mb-0">
                        Showing up to 10 latest persisted telemetry records.
                    </p>
                </div>
                <span class="badge bg-secondary text-white">
                    @Model.RecentReadings.Count reading(s)
                </span>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Received UTC</th>
                            <th scope="col">Device</th>
                            <th scope="col">Sensor</th>
                            <th scope="col">Type</th>
                            <th scope="col" class="text-end">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var reading in Model.RecentReadings)
                    {
                        <tr>
                            <td>@reading.ReceivedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@reading.DeviceId</td>
                            <td>@reading.SensorId</td>
                            <td>@reading.Type</td>
                            <td class="text-end">@reading.Value.ToString("0.00") &deg;@reading.Unit</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5 card-title">No telemetry displayed yet</h2>
            <p class="mb-0">
                Configure the hosted GetRecentTelemetry endpoint before using this page as a live monitoring view.
            </p>
        </div>
    </div>
}
@section Scripts {
    <script>
        const dashboardRefreshIntervalMs = 330000;

        window.setTimeout(function () {
            window.location.reload();
        }, dashboardRefreshIntervalMs);
    </script>
}
